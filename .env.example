# ============================================================
# .env.example — Bioinformatics Pipeline Security Hardening
# ============================================================

# --- Credenciales de registro de contenedores ---
# Necesario si usas imagenes privadas en Docker Hub o GHCR
DOCKER_USERNAME=
DOCKER_TOKEN=

# --- Nextflow Tower ---
# Para monitoreo remoto del pipeline en tower.nf
TOWER_ACCESS_TOKEN=

# --- Almacenamiento en nube (si el pipeline lee/escribe en S3) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=

# --- Notificaciones ---
# Email o Slack webhook para alertas del pipeline
NOTIFICATION_EMAIL=
SLACK_WEBHOOK_URL=